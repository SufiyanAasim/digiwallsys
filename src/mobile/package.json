{
  "name": "@digiwallsys/mobile",
  "license": "MIT",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node scripts/run-package-bin.js expo start",
    "android": "node scripts/run-package-bin.js expo start --android",
    "ios": "node scripts/run-package-bin.js expo start --ios",
    "web": "node scripts/run-package-bin.js expo start --web",
    "lint": "node scripts/run-package-bin.js eslint App.js api.js index.js screens",
    "test": "node --test ../../tests/mobile/*.test.js",
    "build": "node scripts/run-package-bin.js expo export --platform android --output-dir dist",
    "build:web": "node scripts/run-package-bin.js expo export --platform web --output-dir dist-web",
    "build:android:apk": "node scripts/run-package-bin.js eas-cli build --platform android --profile preview",
    "build:android:aab": "node scripts/run-package-bin.js eas-cli build --platform android --profile production",
    "build:ios:ipa": "node scripts/run-package-bin.js eas-cli build --platform ios --profile production"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/native": "^7.1.10",
    "@react-navigation/native-stack": "^7.3.14",
    "axios": "^1.15.3",
    "expo": "~53.0.27",
    "expo-camera": "~16.1.11",
    "expo-device": "~7.1.4",
    "expo-file-system": "~18.1.11",
    "expo-local-authentication": "~57.0.1",
    "expo-notifications": "~0.31.4",
    "expo-secure-store": "~14.2.3",
    "expo-sharing": "~13.1.5",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-qrcode-svg": "^6.3.15",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-web": "^0.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@eslint/js": "^9.28.0",
    "eas-cli": "^21.0.2",
    "eslint": "^9.28.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-native": "^5.0.0",
    "globals": "^16.2.0"
  },
  "private": true
}
