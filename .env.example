# API
PORT=5000
JWT_SECRET=replace-with-at-least-32-random-characters
CORS_ORIGIN=http://localhost:8081,http://localhost:19006
TRUST_PROXY=0
GLOBAL_RATE_LIMIT=120
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30

# PostgreSQL
DATABASE_URL=postgresql://digiwallsys:digiwallsys@localhost:5432/digiwallsys
DATABASE_SSL=false
DATABASE_POOL_SIZE=10

# Risk controls
MAX_TRANSFER_AMOUNT=10000
DAILY_TRANSFER_AMOUNT=25000
HOURLY_TRANSFER_COUNT=20

# Funding provider adapter
FUNDING_PROVIDER=sandbox
FUNDING_PROVIDER_CHECKOUT_URL=
FUNDING_WEBHOOK_SECRET=replace-with-provider-webhook-secret

# Email delivery adapter (development logs masked recipients when omitted)
EMAIL_WEBHOOK_URL=
EMAIL_DELIVERY_TOKEN=

# Background workers
ENABLE_SCHEDULER=true
ENABLE_PUSH_WORKER=true
ENABLE_EMAIL_WORKER=true

# Expo (copy this entry to src/mobile/.env for a physical device)
EXPO_PUBLIC_API_URL=http://localhost:5000
EXPO_PUBLIC_EAS_PROJECT_ID=
